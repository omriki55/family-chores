rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Family-scoped data (new structure)
    match /families/{familyId}/data/{doc} {
      allow read, write: if request.auth != null;
    }
    // Allow listing families collection (admin panel)
    match /families/{familyId} {
      allow read: if request.auth != null;
    }
    // Admin collection (admin panel config + registry)
    match /admin/{document=**} {
      allow read, write: if request.auth != null;
    }
    // Legacy collection (migration support)
    match /family-chores/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
